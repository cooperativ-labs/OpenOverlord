{
  "name": "Overlord",
  "version": "0.2606271849.0",
  "private": true,
  "author": "Cooperativ Labs",
  "description": "Optional Electron desktop shell that wraps the OpenOverlord web control center (the @overlord/webapp SPA + REST/realtime server).",
  "engines": {
    "node": ">=20"
  },
  "main": "dist-electron/main.cjs",
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "node esbuild.mjs && OVERLORD_DESKTOP_DEV=1 electron .",
    "start": "node esbuild.mjs && electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
