{
  "name": "@overlord/webapp",
  "version": "0.2606301356.0",
  "private": true,
  "type": "module",
  "description": "Overlord React SPA that consumes the Overlord backend REST and realtime API.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"yarn dev:server\" \"yarn dev:web\"",
    "dev:server": "yarn workspace @overlord/backend dev",
    "dev:web": "node scripts/write-runtime-config.mjs && vite",
    "build": "node scripts/write-runtime-config.mjs && vite build",
    "build:server": "yarn workspace @overlord/backend build:server",
    "build:server:cloud": "yarn workspace @overlord/backend build:server:cloud",
    "start": "yarn workspace @overlord/backend start",
    "start:bundle": "yarn workspace @overlord/backend start:bundle",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test web/lib/local-target-client.test.ts web/lib/realtime-invalidation.test.ts web/lib/native-workflow-notifications.test.ts web/lib/project-resources.test.ts web/lib/storage-url.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@overlord/automations": "workspace:*",
    "@overlord/contract": "workspace:*",
    "better-auth": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  }
}
