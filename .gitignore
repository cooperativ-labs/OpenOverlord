# Overlord local scratch
.overlord/tmp/
.overlord/logs/

# Per-instance config + link state — generated by `ovld init` / `ovld setup`,
# never committed (see overlord.toml.example). Each deployment owns its own.
/overlord.toml

# Live SQLite database and local object storage
database/.local/

node_modules/
**/node_modules/

.env*
!.env.local.example
!.env.prod.example

dist/
**/dist/
*.tgz

# Serwist generated workers
public/sw*
public/swe-worker*
webapp/public/sw*
webapp/public/swe-worker*
webapp/dist/sw*
webapp/dist/swe-worker*

.yarn/*
!.yarn/releases
!.yarn/releases/**
webapp/.yarn/install-state.gz
**/.yarn/install-state.gz
**/node_modules/.yarn/install-state.gz


**/.DS_Store

# Accidental tsc emit next to sources in @overlord/core/service (including subdirs).
# Never ignore `*.ts` here — Railway CLI upload respects .gitignore and would omit
# tracked sources from the Docker build context.
packages/core/service/**/*.js
packages/core/service/**/*.js.map
packages/core/service/**/*.d.ts
packages/core/service/**/*.d.ts.map

# private-docs
# private-docs/**/*
