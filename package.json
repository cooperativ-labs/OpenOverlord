{
  "name": "overlord",
  "version": "0.1.0",
  "description": "Open-source management and coordination layer for AI coding agents",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.16.0",
  "scripts": {
    "install:all": "yarn install && yarn --cwd webapp install",
    "reinstall": "rm -rf node_modules cli/node_modules webapp/node_modules && yarn install:all",
    "new": "rm -rf node_modules cli/node_modules webapp/node_modules && yarn",
    "dev": "yarn dev:webapp",
    "dev:webapp": "yarn --cwd webapp dev",
    "dev:server": "yarn --cwd webapp dev:server",
    "dev:web": "yarn --cwd webapp dev:web",
    "start": "yarn start:webapp",
    "start:webapp": "yarn --cwd webapp start",
    "stop": "yarn stop:local",
    "build": "tsc --project tsconfig.build.json && yarn build:cli && yarn build:webapp",
    "build:cli": "node cli/scripts/stage-migrations.mjs && tsc --project cli/tsconfig.build.json",
    "build:webapp": "yarn --cwd webapp build",
    "pack:cli": "yarn build:cli && sh -c 'cd cli && npm pack'",
    "stop:local": "node --experimental-strip-types scripts/stop-local-dev.ts",
    "clean": "yarn clean:local",
    "clean:local": "node --experimental-strip-types scripts/clean-local-state.ts",
    "start:local": "node --experimental-strip-types src/database/launch-local.ts",
    "generate": "yarn start:local && kysely-codegen --dialect sqlite --url database/.local/Overlord.sqlite --out-file src/types/db.ts",
    "typecheck": "yarn typecheck:root && yarn typecheck:cli && yarn typecheck:webapp",
    "typecheck:root": "tsc --project tsconfig.build.json --noEmit",
    "typecheck:cli": "tsc --project cli/tsconfig.build.json --noEmit",
    "typecheck:webapp": "yarn --cwd webapp typecheck",
    "test": "yarn test:root && yarn test:cli && yarn test:webapp",
    "test:root": "tsx --test 'src/**/*.test.ts'",
    "test:cli": "yarn build:cli && node --test --experimental-strip-types 'cli/test/**/*.test.ts'",
    "test:webapp": "yarn --cwd webapp test",
    "test:all": "yarn test",
    "lint": "eslint .",
    "fix": "eslint --fix ."
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "better-auth": "^1.2.7",
    "better-sqlite3": "^12.0.0",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "kysely-codegen": "^0.20.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
