{
  "name": "overlord",
  "version": "0.2607141312.0",
  "description": "Open-source management and coordination layer for AI coding agents",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.17.0",
  "workspaces": [
    "auth",
    "automations",
    "backend",
    "database",
    "cli",
    "webapp",
    "desktop",
    "packages/core",
    "packages/contract"
  ],
  "resolutions": {
    "@google/genai": "2.8.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "better-sqlite3": "12.11.1",
    "kysely": "0.29.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "scripts": {
    "install:all": "yarn install && yarn --cwd webapp install && yarn --cwd desktop install && yarn --cwd database install",
    "setup": "yarn install && yarn build:prod && yarn db:start && yarn db:codegen && yarn install",
    "new": "rm -rf node_modules cli/node_modules backend/node_modules webapp/node_modules rm -rf dist backend/dist-server webapp/dist desktop/dist-electron && yarn install:all",
    "dev": "node scripts/with-dev-env.mjs yarn webapp:dev",
    "dev:web": "node scripts/with-dev-env.mjs yarn workspace @overlord/webapp dev:web",
    "start": "yarn start:webapp",
    "start:webapp": "yarn workspace @overlord/webapp start",
    "stop": "yarn stop:local",
    "stop:local": "tsx scripts/stop-local-dev.ts",
    "check:native": "tsx scripts/check-native-runtime.ts",
    "check:native:fix": "tsx scripts/check-native-runtime.ts --fix",
    "auth:build:prod": "yarn workspace @overlord/auth build",
    "automations:build:prod": "yarn workspace @overlord/automations build",
    "core:build:prod": "yarn workspace @overlord/core build",
    "contract:build:prod": "yarn workspace @overlord/contract build",
    "cli:build:prod": "yarn workspace overlord-cli build",
    "cli:pack:prod": "yarn cli:build:prod && yarn workspace overlord-cli pack",
    "cli:publish": "yarn cli:build:prod && node --import tsx scripts/publish-cli.ts",
    "db:path": "tsx scripts/print-db-path.ts",
    "db:start": "node scripts/with-dev-env.mjs sh -c 'OVERLORD_SQLITE_PATH=\"$(tsx scripts/print-db-path.ts)\" tsx database/src/launch-local.ts'",
    "db:clean": "tsx scripts/clean-local-state.ts",
    "db:reset": "yarn db:clean && yarn db:start",
    "db:codegen": "yarn db:start && node scripts/with-dev-env.mjs sh -c 'kysely-codegen --dialect sqlite --url \"$(tsx scripts/print-db-path.ts)\" --out-file packages/core/types/db.ts'",
    "db:build:prod": "yarn workspace @overlord/database build",
    "db:migrate:postgres": "node scripts/with-prod-env.mjs tsx scripts/migrate-postgres.ts",
    "admin:delete-user": "node scripts/with-prod-env.mjs tsx scripts/delete-user.ts",
    "desktop:build:prod": "yarn webapp:build:prod && yarn server:build:prod && yarn workspace Overlord build",
    "desktop:dev": "yarn workspace Overlord dev",
    "desktop:typecheck": "yarn workspace Overlord typecheck",
    "desktop:package:prod": "tsx scripts/build-desktop.ts",
    "desktop:publish": "node --import tsx scripts/publish-desktop-release.ts",
    "server:build:prod": "yarn workspace @overlord/backend build:server",
    "server:build:cloud": "yarn workspace @overlord/backend build:server:cloud",
    "server:dev": "node scripts/with-dev-env.mjs yarn workspace @overlord/backend dev",
    "webapp:build:prod": "yarn workspace @overlord/webapp build",
    "webapp:dev": "node scripts/with-dev-env.mjs yarn workspace @overlord/webapp dev",
    "typecheck": "yarn db:build:prod && yarn auth:build:prod && yarn automations:build:prod && yarn contract:build:prod && yarn typecheck:core && yarn typecheck:cli && yarn typecheck:backend && yarn typecheck:webapp",
    "typecheck:auth": "yarn workspace @overlord/auth typecheck",
    "typecheck:automations": "yarn workspace @overlord/automations typecheck",
    "typecheck:core": "yarn workspace @overlord/core typecheck",
    "typecheck:root": "yarn typecheck:core",
    "typecheck:cli": "yarn workspace overlord-cli typecheck",
    "typecheck:backend": "yarn workspace @overlord/backend typecheck",
    "typecheck:webapp": "yarn workspace @overlord/webapp typecheck",
    "test": "yarn check:native:fix && yarn db:build:prod && yarn auth:build:prod && yarn automations:build:prod && yarn test:database && yarn test:root && yarn test:auth && yarn test:automations && yarn test:cli && yarn test:backend && yarn test:webapp",
    "test:core": "node scripts/with-ovld-home.mjs yarn workspace @overlord/core test",
    "test:root": "yarn test:core",
    "test:database": "node scripts/with-ovld-home.mjs yarn workspace @overlord/database test",
    "test:auth": "node scripts/with-ovld-home.mjs yarn workspace @overlord/auth test",
    "test:automations": "node scripts/with-ovld-home.mjs yarn workspace @overlord/automations test",
    "test:cli": "node scripts/with-ovld-home.mjs yarn workspace overlord-cli test",
    "test:cli:e2e": "node scripts/with-ovld-home.mjs yarn workspace overlord-cli test:e2e",
    "test:backend": "node scripts/with-ovld-home.mjs yarn workspace @overlord/backend test",
    "test:webapp": "node scripts/with-ovld-home.mjs yarn workspace @overlord/webapp test",
    "test:all": "yarn test",
    "test:watch": "node scripts/with-ovld-home.mjs tsx --test --watch 'packages/core/**/*.test.ts'",
    "check": "yarn lint && yarn typecheck && yarn test",
    "lint": "eslint .",
    "fix": "eslint --fix .",
    "build:prod": "yarn db:build:prod && yarn auth:build:prod && yarn automations:build:prod && yarn core:build:prod && yarn cli:build:prod && yarn webapp:build:prod",
    "ovld:dev": "node scripts/with-dev-env.mjs yarn cli:build:prod && node scripts/with-dev-env.mjs node cli/bin/ovld.mjs",
    "generate": "yarn db:codegen",
    "version:update:minor": "node scripts/version-update.mjs",
    "connectors:version:bump": "node scripts/sync-connector-versions.mjs --bump patch",
    "connectors:version:sync": "node scripts/sync-connector-versions.mjs --sync",
    "connectors:version:check": "node scripts/sync-connector-versions.mjs --check"
  },
  "dependencies": {
    "@overlord/auth": "workspace:*",
    "@overlord/database": "workspace:*",
    "kysely": "^0.29.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "kysely-codegen": "^0.20.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
