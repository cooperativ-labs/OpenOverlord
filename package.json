{
  "name": "overlord",
  "version": "0.2606181404.0",
  "description": "Open-source management and coordination layer for AI coding agents",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.16.0",
  "workspaces": [
    "auth",
    "automations",
    "database",
    "cli",
    "webapp",
    "desktop"
  ],
  "resolutions": {
    "@google/genai": "2.8.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "better-sqlite3": "12.11.1",
    "kysely": "0.29.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "scripts": {
    "install:all": "yarn install && yarn --cwd webapp install && yarn --cwd desktop install && yarn --cwd database install",
    "setup": "yarn install && yarn build && yarn db:start && yarn db:codegen && yarn install",
    "new": "rm -rf node_modules cli/node_modules webapp/node_modules rm -rf dist webapp/dist webapp/dist-server desktop/dist-electron && yarn install:all",
    "dev": "yarn dev:webapp",
    "dev:webapp": "yarn workspace @overlord/webapp dev",
    "dev:server": "yarn workspace @overlord/webapp dev:server",
    "dev:web": "yarn workspace @overlord/webapp dev:web",
    "start": "yarn start:webapp",
    "start:webapp": "yarn workspace @overlord/webapp start",
    "stop": "yarn stop:local",
    "stop:local": "tsx scripts/stop-local-dev.ts",
    "build": "yarn build:db && yarn build:auth && yarn build:automations && tsc --project tsconfig.build.json && yarn build:cli && yarn build:webapp",
    "build:auth": "yarn workspace @overlord/auth build",
    "build:automations": "yarn workspace @overlord/automations build",
    "build:db": "yarn workspace @overlord/database build",
    "build:cli": "yarn workspace open-overlord build",
    "build:webapp": "yarn workspace @overlord/webapp build",
    "pack:cli": "yarn build:cli && sh -c 'cd cli && npm pack'",
    "cli:publish": "yarn build:cli && sh -c 'cd cli && npm publish'",
    "ovld:dev": "yarn build:cli && node scripts/with-ovld-home.mjs node cli/bin/ovld.mjs",
    "build:server": "yarn workspace @overlord/webapp build:server",
    "desktop:build": "yarn build:webapp && yarn build:server && yarn workspace @overlord/desktop build",
    "desktop:dev": "yarn workspace @overlord/desktop dev",
    "desktop:typecheck": "yarn workspace @overlord/desktop typecheck",
    "desktop:package": "tsx scripts/build-desktop.ts",
    "desktop:publish": "node --import tsx scripts/publish-desktop-release.ts",
    "typecheck": "yarn build:db && yarn build:auth && yarn build:automations && yarn typecheck:root && yarn typecheck:cli && yarn typecheck:webapp",
    "typecheck:auth": "yarn workspace @overlord/auth typecheck",
    "typecheck:automations": "yarn workspace @overlord/automations typecheck",
    "typecheck:root": "tsc --project tsconfig.build.json --noEmit",
    "typecheck:cli": "yarn workspace open-overlord typecheck",
    "typecheck:webapp": "yarn workspace @overlord/webapp typecheck",
    "test": "yarn build:db && yarn build:auth && yarn build:automations && yarn test:root && yarn test:auth && yarn test:automations && yarn test:cli && yarn test:webapp",
    "test:root": "node scripts/with-ovld-home.mjs tsx --test 'src/**/*.test.ts'",
    "test:auth": "node scripts/with-ovld-home.mjs yarn workspace @overlord/auth test",
    "test:automations": "node scripts/with-ovld-home.mjs yarn workspace @overlord/automations test",
    "test:cli": "node scripts/with-ovld-home.mjs yarn workspace open-overlord test",
    "test:webapp": "node scripts/with-ovld-home.mjs yarn workspace @overlord/webapp test",
    "test:all": "yarn test",
    "test:watch": "node scripts/with-ovld-home.mjs tsx --test --watch 'src/**/*.test.ts'",
    "check": "yarn lint && yarn typecheck && yarn test",
    "lint": "eslint .",
    "fix": "eslint --fix .",
    "db:path": "tsx scripts/print-db-path.ts",
    "db:start": "OVERLORD_SQLITE_PATH=\"$(tsx scripts/print-db-path.ts)\" tsx database/src/launch-local.ts",
    "db:clean": "tsx scripts/clean-local-state.ts",
    "db:reset": "yarn db:clean && yarn db:start",
    "db:codegen": "yarn db:start && kysely-codegen --dialect sqlite --url \"$(tsx scripts/print-db-path.ts)\" --out-file src/types/db.ts",
    "start:local": "yarn db:start",
    "clean": "yarn db:clean",
    "clean:local": "yarn db:clean",
    "generate": "yarn db:codegen",
    "version:update:minor": "node scripts/version-update.mjs"
  },
  "dependencies": {
    "@overlord/auth": "workspace:*",
    "@overlord/database": "workspace:*",
    "kysely": "^0.29.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "kysely-codegen": "^0.20.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
