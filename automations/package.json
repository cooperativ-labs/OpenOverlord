{
  "name": "@overlord/automations",
  "version": "0.1.0",
  "description": "Overlord automations layer: built-in automation registry and reference automation tools.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "zod": "^4.4.1"
  },
  "license": "MIT"
}
