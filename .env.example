# Optional Gemini provider for automations (summarization, objective titles).
# Copy to .env and set your key to enable Gemini-backed automations.
GEMINI_API_KEY=

# Optional model override. Defaults to gemini-2.5-flash-lite.
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional production/packaged web server runtime overrides.
# OVERLORD_WEB_HOST=127.0.0.1
# OVERLORD_WEB_PORT=4310      # Express REST/SSE API port (server/index.ts).
# OVLD_HOME=~/.ovld          # Production data dir. Use a different value for development.

# Development overrides belong in .env.local, not in this file. That allows a
# packaged production instance to keep using .env while source development uses
# different ports and a different OVLD_HOME at the same time. See
# .env.local.example.

# Optional SQL Studio runtime overrides.
# OVERLORD_SQL_STUDIO_ENABLED=false
# OVERLORD_SQL_STUDIO_HOST=127.0.0.1
# OVERLORD_SQL_STUDIO_PORT=4311
# OVERLORD_SQL_STUDIO_BINARY=sql-studio

# Optional desktop update feed override (default: GitHub Releases — desktop/update-feed.ts).
# OVERLORD_UPDATE_FEED_URL=https://github.com/cooperativ-labs/OpenOverlord/releases/latest/download/
# (custom-automation extension point). Comma-separated package names or paths;
# each module registers its automations as an import side effect. Lets a fork
# that tracks OpenOverlord add automations without editing the built-in registry.
# OVERLORD_AUTOMATIONS_MODULE=@your-org/overlord-automations
