{
  "name": "@overlord/core",
  "version": "0.1.0",
  "description": "Overlord protocol/service core: shared service, repository, and generated database types.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/types/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./service/*": {
      "types": "./dist/service/*.d.ts",
      "default": "./dist/service/*.js"
    },
    "./repository/*": {
      "types": "./dist/repository/*.d.ts",
      "default": "./dist/repository/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "../../node_modules/.bin/tsc --project tsconfig.build.json",
    "typecheck": "../../node_modules/.bin/tsc --project tsconfig.build.json --noEmit",
    "test": "node ../../scripts/with-ovld-home.mjs tsx --test '**/*.test.ts'"
  },
  "dependencies": {
    "@overlord/auth": "workspace:*",
    "@overlord/database": "workspace:*",
    "kysely": "^0.29.2"
  },
  "license": "MIT"
}
