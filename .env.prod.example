# Production / packaged app defaults. Copy to `.env.prod`.
#
# The desktop packager copies only the runtime app keys below into the bundled
# `.env.prod`; build-time secrets such as `APPLE_*` are consumed during packaging
# but are not shipped in the desktop app.
# Runtime values in `.env.prod` are used as defaults when a packaged app creates
# the user's `overlord.toml`.

GEMINI_API_KEY=

APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
APPLE_ID=

OVERLORD_WEB_HOST=127.0.0.1
OVERLORD_WEB_PORT=4310      # Express REST/SSE API port (server/index.ts).

OVERLORD_SQL_STUDIO_HOST=127.0.0.1
OVERLORD_SQL_STUDIO_PORT=4311
OVERLORD_SQL_STUDIO_BINARY=sql-studio
