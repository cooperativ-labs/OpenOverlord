# Production / packaged app defaults. Copy to `.env.prod`.
#
# The desktop packager copies only the runtime app keys below into the bundled
# `.env.prod`; build-time secrets such as `APPLE_*` are consumed during packaging
# but are not shipped in the desktop app.
# Runtime values in `.env.prod` are used as defaults when a packaged app creates
# the user's `overlord.toml`.

GEMINI_API_KEY=

APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
APPLE_ID=
NPM_TOKEN=

OVERLORD_WEB_HOST=127.0.0.1
OVERLORD_WEB_PORT=4310      # Express REST/SSE API port (backend/index.ts).
OVERLORD_BACKEND_URL=http://127.0.0.1:4310

OVERLORD_SQL_STUDIO_HOST=127.0.0.1
OVERLORD_SQL_STUDIO_PORT=4311
OVERLORD_SQL_STUDIO_BINARY=sql-studio

# ---- Overlord Cloud (hosted backend) ------------------------------------
# Set these only for the hosted control plane (Railway + Neon). Local/desktop
# editions leave DATABASE_URL unset and run on SQLite. See the operator runbook
# at private-docs/deployment-overlord-cloud.md (git-ignored).
#
# Hosted Postgres system of record. A postgres:// value selects the Postgres
# adapter for both the data layer and Better Auth (resolveAdapter). Use the
# Neon DIRECT (non-pooled) connection string for migrations; the always-on
# backend can use the direct string too (a bounded pg Pool is the warm pool).
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
#
# Stable Better Auth signing secret so sessions survive restarts/redeploys.
# Generate with: openssl rand -base64 32
# BETTER_AUTH_SECRET=
# Public HTTPS origin of the hosted backend (cookie/redirect base).
# BETTER_AUTH_URL=https://overlord-backend.up.railway.app
#
# In the container the server binds OVERLORD_WEB_HOST=0.0.0.0 and
# OVERLORD_WEB_PORT=$PORT (Railway-injected); SQL Studio is disabled.
#
# Comma-separated browser origins allowed for CORS and Better Auth when the SPA
# is hosted on Vercel (production + preview URLs).
# OVERLORD_WEB_ORIGINS=https://overlord-webapp.vercel.app,https://overlord-webapp-*.vercel.app
