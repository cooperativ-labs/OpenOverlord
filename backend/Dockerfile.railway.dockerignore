# Default-deny the Railway backend build context. Re-include only manifests,
# TypeScript config, backend/shared source, Postgres migrations, and the small
# CLI config subset imported by the backend.
**

!package.json
!yarn.lock
!.yarnrc.yml
!.yarn/
!.yarn/releases/
!.yarn/releases/**
!tsconfig.json
!tsconfig.build.json

!auth/
!auth/package.json
!auth/tsconfig.json
!auth/tsconfig.build.json
!auth/src/
!auth/src/**

!automations/
!automations/package.json
!automations/tsconfig.json
!automations/tsconfig.build.json
!automations/src/
!automations/src/**

!backend/
!backend/package.json
!backend/tsconfig.json
!backend/scripts/
!backend/scripts/build-server.mjs
!backend/*.ts
!backend/Dockerfile.railway
!backend/Dockerfile.railway.dockerignore

!mcp/
!mcp/server.ts

!database/
!database/package.json
!database/tsconfig.json
!database/tsconfig.build.json
!database/src/
!database/src/**
!database/postgres/
!database/postgres/migrations/
!database/postgres/migrations/**

!packages/
!packages/contract/
!packages/contract/package.json
!packages/contract/tsconfig.build.json
!packages/contract/src/
!packages/contract/src/**
!packages/core/
!packages/core/package.json
!packages/core/tsconfig.build.json
!packages/core/repository/
!packages/core/repository/**
!packages/core/service/
!packages/core/service/**
!packages/core/types/
!packages/core/types/**

!webapp/
!webapp/package.json
!webapp/tsconfig.json
!webapp/shared/
!webapp/shared/**

!cli/
!cli/package.json
!cli/src/
!cli/src/agent-catalog.ts
!cli/src/agent-catalog-defaults.ts
!cli/src/config.ts
!cli/src/env.ts
!cli/src/errors.ts
!cli/src/redact-secrets.ts
!cli/src/terminal-profile-types.ts

!desktop/
!desktop/package.json

**/*.test.ts
**/*.fixture.ts
**/test-helpers.ts
**/docs/**
**/README.md
**/dist/**
**/node_modules/**
**/.DS_Store
**/*.log
.env
