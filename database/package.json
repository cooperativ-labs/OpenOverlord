{
  "name": "@overlord/database",
  "version": "0.1.0",
  "description": "Overlord persistence layer: SQLite migrations, connection/migration runtime, local launcher, and adapter selection.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "sqlite/migrations/",
    "postgres/migrations/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "db:start": "tsx src/launch-local.ts",
    "test": "node --import tsx --test src/client.postgres-conformance.test.ts src/ext-everhour-migration.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "license": "MIT"
}
