{
  "name": "overlord-cli",
  "version": "0.1.0",
  "description": "Overlord CLI — management, agent protocol, and runner for OpenOverlord",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "overlord": "bin/ovld.mjs",
    "ovld": "bin/ovld.mjs"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "test": "yarn build && tsx --test 'test/**/*.test.ts'",
    "prepack": "tsc --project tsconfig.build.json && node scripts/vendor-database.mjs",
    "postpack": "node scripts/vendor-database.mjs restore"
  },
  "dependencies": {
    "@overlord/database": "workspace:*",
    "better-sqlite3": "^12.0.0",
    "smol-toml": "^1.6.1"
  },
  "bundleDependencies": [
    "@overlord/database"
  ],
  "keywords": [
    "overlord",
    "ai",
    "agents",
    "cli"
  ],
  "license": "MIT"
}
