{
  "name": "overlord-cli",
  "version": "0.1.0",
  "description": "Overlord CLI — management, agent protocol, and runner for OpenOverlord",
  "type": "module",
  "private": true,
  "packageManager": "yarn@4.16.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "overlord": "bin/ovld.mjs",
    "ovld": "bin/ovld.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "database/sqlite/migrations/"
  ],
  "scripts": {
    "build": "node scripts/stage-migrations.mjs && tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types 'test/**/*.test.ts'",
    "prepack": "node scripts/stage-migrations.mjs && tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "smol-toml": "^1.6.1"
  },
  "keywords": [
    "overlord",
    "ai",
    "agents",
    "cli"
  ],
  "license": "MIT"
}
