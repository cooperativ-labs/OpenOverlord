{
  "name": "open-overlord",
  "version": "0.2606191041.0",
  "description": "Overlord CLI — management, agent protocol, and runner for OpenOverlord",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "overlord": "bin/ovld.mjs",
    "ovld": "bin/ovld.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/postinstall.mjs"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "yarn clean && ../node_modules/.bin/tsc --project tsconfig.build.json",
    "typecheck": "../node_modules/.bin/tsc --project tsconfig.build.json --noEmit",
    "test": "yarn build && tsx --test 'test/**/*.test.ts'",
    "prepack": "yarn build",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "smol-toml": "^1.6.1"
  },
  "keywords": [
    "overlord",
    "ai",
    "agents",
    "cli",
    "ovld"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
