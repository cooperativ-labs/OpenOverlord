# In-repo development instance. Copy to `.env.local`.
#
# This file isolates source development from the global/production instance:
#   - Production / Desktop: `~/.ovld` data, API on :4310 (see `.env.prod`)
#   - In-repo dev:          repo-local data, API on :4320 (this file)
#
# Source workflows (`yarn dev`, `yarn db:*`, `yarn ovld:dev`) read `.env.local`
# only. Packaged production reads `.env.prod` only. Both can run at the same time.

GEMINI_API_KEY=

APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
APPLE_ID=

# Repo-local data dir (SQLite, auth.json, connector state, VCS baselines).
# Git-ignored under database/.local/.
OVLD_HOME=database/.local/dev-home

# Dev API port — must differ from production :4310 in overlord.toml.
OVERLORD_WEB_HOST=127.0.0.1
OVERLORD_WEB_PORT=4320

# Vite SPA dev-server port.
OVERLORD_WEB_DEV_PORT=5173

# In-repo CLI/protocol commands target the dev API, not :4310.
OVERLORD_BACKEND_URL=http://127.0.0.1:4320

# Optional: keep SQL Studio on a separate dev port too.
OVERLORD_SQL_STUDIO_HOST=127.0.0.1
OVERLORD_SQL_STUDIO_PORT=4321
OVERLORD_SQL_STUDIO_BINARY=sql-studio
