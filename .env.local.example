# Development-only overrides. Copy to .env.local.
#
# The source web server and Vite dev server load `.env`, then overlay
# `.env.local`. Packaged/bundled production does not load `.env.local`.

# Keep development data separate from a packaged production instance.
OVLD_HOME=.overlord/dev-home

# Development API/server port. Use a different port than production.
OVERLORD_WEB_PORT=4320

# Development Vite SPA port.
OVERLORD_WEB_DEV_PORT=5173

# Make in-repo CLI/protocol commands target the development API.
OVERLORD_BACKEND_URL=http://127.0.0.1:4320

# Optional: keep SQL Studio separate too.
# OVERLORD_SQL_STUDIO_PORT=4321
